{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fx-fundamentals-refresher.local/schemas/fundamental-differential.response.schema.json",
  "title": "FundamentalDifferentialResponse",
  "type": "object",
  "required": ["meta", "data"],
  "properties": {
    "meta": { "$ref": "common.schema.json#/definitions/ResponseMeta" },
    "error": {
      "oneOf": [
        { "$ref": "common.schema.json#/definitions/ErrorObject" },
        { "type": "null" }
      ]
    },
    "data": {
      "type": "object",
      "required": [
        "base",
        "quote",
        "active_pair",
        "pair_source",
        "inflation_mode",
        "rate_differential",
        "rate_reason",
        "inflation_differential",
        "inflation_reason",
        "rate_trend",
        "rate_metric"
      ],
      "properties": {
        "base": { "type": "string" },
        "quote": { "type": "string" },
        "active_pair": { "type": "string" },
        "pair_source": { "type": "string", "enum": ["query", "base_quote", "fallback"] },
        "strength_watchlist_default": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inflation_mode": { "type": "string", "enum": ["yoy", "mom"] },
        "rate_differential": { "type": ["number", "null"] },
        "rate_reason": { "type": "string" },
        "inflation_differential": { "type": ["number", "null"] },
        "inflation_reason": { "type": "string" },
        "rate_trend": { "type": "string" },
        "rate_metric": {
          "type": "object",
          "required": ["signed_value", "unit", "trend_badge", "tooltip", "na_reason", "detail"],
          "properties": {
            "signed_value": { "type": ["number", "null"] },
            "unit": { "type": "string", "enum": ["pp"] },
            "trend_badge": { "type": "string" },
            "tooltip": { "type": "string" },
            "na_reason": { "type": "string" },
            "detail": {
              "type": "object",
              "required": ["raw_components", "source_series_ids", "as_of_utc", "last_refreshed_utc"],
              "properties": {
                "raw_components": {
                  "type": "object",
                  "required": ["base_rate_pp", "quote_rate_pp", "formula"],
                  "properties": {
                    "base_rate_pp": { "type": ["number", "null"] },
                    "quote_rate_pp": { "type": ["number", "null"] },
                    "formula": { "type": "string" }
                  },
                  "additionalProperties": true
                },
                "source_series_ids": {
                  "type": "object",
                  "required": ["base", "quote"],
                  "properties": {
                    "base": { "type": "string" },
                    "quote": { "type": "string" }
                  },
                  "additionalProperties": true
                },
                "as_of_utc": {
                  "type": "object",
                  "required": ["base", "quote", "effective"],
                  "properties": {
                    "base": { "type": "string" },
                    "quote": { "type": "string" },
                    "effective": { "type": "string" }
                  },
                  "additionalProperties": true
                },
                "last_refreshed_utc": { "type": "string" }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
